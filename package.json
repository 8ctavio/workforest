{
	"name": "workforest",
	"displayName": "Workforest",
	"publisher": "8ctavio",
	"version": "0.0.0",
	"license": "MIT",
	"private": true,
	"author": "Octavio Araiza (https://github.com/8ctavio)",
	"type": "module",
	"main": "./src/extension.js",
	"scripts": {
		"lint": "oxlint",
		"typecheck": "tsc"
	},
	"activationEvents": [],
	"contributes": {
		"configuration": {
			"title": "Workforest",
			"properties": {
				"workforest.workspaceDirectory": {
					"type": "string",
					"default": "",
					"description": "Path to directory with workspace files (.code-workspace)"
				}
			}
		},
		"commands": [
			{
				"command": "workforest.addWorktree",
				"title": "Add Worktree",
				"icon": "$(git-branch-staged-changes)"
			},{
				"command": "workforest.removeWorktree",
				"title": "Remove Worktree",
				"icon": "$(trash)"
			},{
				"command": "workforest.openWorktree",
				"title": "Open Worktree",
				"icon": "$(window)"
			},{
				"command": "workforest.openWorktreeInNewWindow",
				"title": "Open Worktree in New Window",
				"icon": "$(empty-window)"
			},{
				"command": "workforest.revealWorktreeInFileExplorer",
				"title": "Reveal Worktree in File Explorer",
				"icon": "$(file-submodule)"
			},{
				"command": "workforest.refreshWorktrees",
				"title": "Refresh Worktrees",
				"icon": "$(refresh)"
			},{
				"command": "workforest.selectWorkspaceDirectory",
				"title": "Select Workspace Directory",
				"icon": "$(folder)"
			},{
				"command": "workforest.openWorkspaceFile",
				"title": "Open Workspace File",
				"icon": "$(go-to-file)"
			},{
				"command": "workforest.refreshWorkspaceDirectory",
				"title": "Refresh Workspace Directory",
				"icon": "$(refresh)"
			}
		],
		"viewsContainers": {
			"activitybar": [{
				"id": "workforest",
				"title": "Workforest",
				"icon": "resources/forest.svg"
			}]
		},
		"views": {
			"workforest": [{
				"id": "worktrees",
				"name": "Worktrees",
				"icon": "($repo)",
				"visibility": "visible"
			},{
				"id": "workspaces",
				"name": "Workspaces",
				"icon": "$(project)",
				"visibility": "collapsed"
			}]
		},
		"viewsWelcome": [
			{
				"view": "worktrees",
				"contents": "No repositories detected"
			},{
				"view": "workspaces",
				"when": "!config.workforest.workspaceDirectory",
				"contents": "[Add workspace directory](command:workforest.selectWorkspaceDirectory)"
			},{
				"view": "workspaces",
				"when": "config.workforest.workspaceDirectory",
				"contents": "No workspace files found"
			}
		],
		"menus": {
			"view/title": [
				{
					"when": "view == worktrees",
					"command": "workforest.refreshWorktrees",
					"group": "navigation"
				},{
					"when": "view == workspaces",
					"command": "workforest.selectWorkspaceDirectory",
					"group": "navigation@1"
				},{
					"when": "view == workspaces",
					"command": "workforest.refreshWorkspaceDirectory",
					"group": "navigation@2"
				}
			],
			"view/item/context": [
				{
					"when": "view == worktrees && viewItem == repository",
					"command": "workforest.addWorktree",
					"group": "inline@1"
				},{
					"when": "view == worktrees && viewItem == repository",
					"command": "workforest.refreshWorktrees",
					"group": "inline@2"
				},{
					"when": "view == worktrees && viewItem == worktree",
					"command": "workforest.openWorktreeInNewWindow",
					"group": "inline@1"
				},{
					"when": "view == worktrees && viewItem == worktree",
					"command": "workforest.revealWorktreeInFileExplorer",
					"group": "inline@2"
				},{
					"when": "view == worktrees && viewItem == worktree",
					"command": "workforest.removeWorktree",
					"group": "inline@3"
				},{
					"when": "view == workspaces",
					"command": "workforest.openWorkspaceFile",
					"group": "inline"
				}
			]
		}
	},
	"capabilities": {
		"untrustedWorkspaces": {
			"supported": false
		}
	},
	"extensionDependencies": ["vscode.git"],
	"packageManager": "pnpm@10.30.0",
	"engines": {
		"vscode": "^1.74.0"
	},
	"devDependencies": {
		"@types/node": "catalog:",
		"@types/vscode": "catalog:",
		"oxlint": "catalog:",
		"typescript": "catalog:"
	}
}