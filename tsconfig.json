{
	"compilerOptions": {
		"allowJs": true,
		"checkJs": true,
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"moduleDetection": "force",
		"noEmit": true,
		"skipLibCheck": true,
		"erasableSyntaxOnly": true,
		"verbatimModuleSyntax": true,
		"strict": true,
		"noImplicitOverride": true,
		"noUncheckedIndexedAccess": true,
	},
	"include": ["src"]
}