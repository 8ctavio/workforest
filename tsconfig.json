{
	"compilerOptions": {
		"noEmit": true,
		"allowJs": true,
		"checkJs": true,
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"moduleDetection": "force",
		"skipLibCheck": true,
		"erasableSyntaxOnly": true,
		"verbatimModuleSyntax": true,
		"noImplicitOverride": true,
		"noUncheckedIndexedAccess": true,
		"types": ["node", "vscode"]
	},
	"include": ["src"]
}